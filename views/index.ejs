<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CV</title>
    <link rel="stylesheet" href="css/style.css">
    <script src="https://kit.fontawesome.com/5c744c82f2.js" crossorigin="anonymous"></script>
</head>
<body>
    <div class="container">
        <header>
            <h1><%= cv.cv %></h1>
            <p class="author">By <span id="fName"><%= cv.fName %></span></p>
            <div class="rating">
                <ul class="rating-stars">
                    <li><i class="fa-solid fa-star"></i></li>
                    <li><i class="fa-solid fa-star"></i></li>
                    <li><i class="fa-solid fa-star"></i></li>
                    <li><i class="fa-solid fa-star"></i></li>
                    <li><i class="fa-solid fa-star"></i></li>
                </ul>
                <span class="rating-count">(123)</span>
            </div>

            <div class="image-container">
                <div class="cv-image">
                    <img src="images/1.jpg" alt="cv-image">
                </div>
            </div>
        </header>

        <section class="main">
            <div class="contact-info">
                <h2 class="main-title">Kontakt Andmed</h2>
                <p class="contact-text" id="contactDetails">
                    <%= cv.fName %> <%= cv.lName %><br>
                    <%= cv.email %><br>
                    <%= cv.address %><br>
                    <%= cv.phone %>
                </p>
            </div>

            <div class="experience">
                <h2 class="main-title">Töökogemus</h2>
                <p class="experience-text" id="experience"><%= cv.experience %></p>
            </div>

            <div class="education">
                <h2 class="main-title">Hariduskäik</h2>
                <p class="education-text" id="education"><%= cv.education %></p>
            </div>

            <div class="qualifications">
                <h2 class="main-title">Kvalifikatsioonid</h2>
                <p class="qualifications-text" id="qualification"><%= cv.qualification %></p>
            </div>

            <div class="languages">
                <h2 class="main-title">Keelteoskus</h2>
                <p class="languages-text" id="languages"><%- cv.languages %></p>
            </div>          

            <div class="interests">
                <h2 class="main-title">Hobid ja huvid</h2>
                <ul class="interests-list" id="interests">
                    <% cv.interests.forEach(interest => { %>
                        <li><%= interest %></li>
                    <% }) %>
                </ul>
            </div>

            <hr>

            <div class="reviews">
                <form action="/reviews">
                    <div class="review-box">
                        <textarea name="review" id="review"></textarea>
                    </div>
                    <div class="reviews-stars">
                        <ul class="rating-stars">
                            <li><i class="fa-regular fa-star"></i></li>
                            <li><i class="fa-regular fa-star"></i></li>
                            <li><i class="fa-regular fa-star"></i></li>
                            <li><i class="fa-regular fa-star"></i></li>
                            <li><i class="fa-regular fa-star"></i></li>
                        </ul>
                    </div>
                    <div class="reviews-btn-container">
                        <button type="submit">Send review</button>
                    </div>
                </form>
            </div>
            <hr>
        </section>

        <footer>
            <div class="social-media">
                <ul class="social-media-list">
                    <li><a href="#"><i class="fa-brands fa-instagram"></i></a></li>
                    <li><a href="#"><i class="fa-brands fa-facebook"></i></a></li>
                </ul>
            </div>
            <div class="contact-link">
                <ul class="contact-links-list">
                    <li><a href="#">About me</a></li>
                </ul>
            </div>
            <div class="copyright">
                <span id="copyright">2026 &#169;</span>
            </div>
        </footer>
    </div>
    <script src="app.js"></script>
</body>
</html>